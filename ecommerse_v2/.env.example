# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/v2/
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database?retryWrites=true&w=majority
ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/database_electripay?retryWrites=true&w=majority

# Server Environment
NODE_ENV=production
PORT=5000

# CORS Allowed Origins (comma-separated for production)
# For Vercel frontend: https://electripay.vercel.app
# For local development: http://localhost:3000,http://localhost:8081,http://localhost:5173
CORS_ORIGIN=https://electripay.vercel.app

# Ngrok (Optional - for public tunnel to expose local server)
# Get token from: https://dashboard.ngrok.com/auth/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_token_here
NGROK_REGION=us

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# CRITICAL: Backend API URL for frontend
# This env var MUST be set when deploying frontend (e.g., on Vercel)
# Local dev: http://localhost:5000
# Production: https://your-backend-api.herokuapp.com (or your backend URL)
EXPO_PUBLIC_API_URL=https://your-backend-api.herokuapp.com
