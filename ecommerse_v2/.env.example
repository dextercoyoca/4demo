# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/v2/
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database?retryWrites=true&w=majority
ATLAS_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/database_electripay?retryWrites=true&w=majority

# Environment
NODE_ENV=production

# Ngrok (Optional - for public tunnel access)
# Get token from: https://dashboard.ngrok.com/auth/your-authtoken
NGROK_AUTH_TOKEN=your_ngrok_token_here

# API Configuration
LOCAL_API_URL=http://localhost:5000

# CORS Allowed Origins (comma-separated for production)
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# Port
PORT=5000

# Ngrok Region (us, eu, ap, au, sa, jp, in)
NGROK_REGION=us
